{
  "env": {
    "node": true,
    "es2021": true
  },
  "extends": ["eslint:recommended"],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "ignorePatterns": ["dist/"],
  "overrides": [
    {
      "files": ["*.ts"],
      "parser": "@typescript-eslint/parser",
      "rules": {
        "no-unused-vars": "off",
        "no-undef": "off"
      }
    },
    {
      "files": ["test/**/*.ts", "test/**/*.js"],
      "env": {
        "jest": true,
        "node": true
      },
      "rules": {
        "no-undef": "off"
      }
    }
  ],
  "rules": {
    "no-unused-vars": ["warn"],
    "no-console": "off"
  }
}
